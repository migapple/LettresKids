{
  "appId": "com.michel.garlandat.lettreskids",
  "appName": "Lettres Kids",
  "webDir": "www/",
  "bundledWebRuntime": false,
  "backgroundColor": "#070510",
  "ios": {
    "backgroundColor": "#070510",
    "contentInset": "automatic",
    "scrollEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "Geolocation": {
      "permissions": ["location"]
    },
    "server": {
      "allowNavigation": ["nominatim.openstreetmap.org"]
    }
  }
}
